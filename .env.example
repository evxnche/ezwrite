VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_LANDING_PAGE_URL=https://ezwrite.evanche.xyz

# Server-only — Vite dev proxy + Vercel api/openrouter. Never use VITE_* for this.
OPENROUTER_API_KEY=your-openrouter-api-key

# Server-only — powers /api/agent (the agent shared-canvas feature). Never VITE_*.
# Service role bypasses RLS to mint passkeys, queue agent edits, and read snapshots.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
# Secret used to HMAC-hash agent passkeys before storing them. Any long random string.
AGENT_PASSKEY_PEPPER=change-me-to-a-long-random-secret
